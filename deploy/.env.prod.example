# Production runtime environment example.
# Copy this file to .env.prod on the server and fill in real values.

# Image registry
# Example:
# - ACR personal edition: crpi-xxxx.cn-hangzhou.personal.cr.aliyuncs.com/your-namespace
# - GHCR fallback: ghcr.io/your-github-owner
IMAGE_NAMESPACE=registry.example.com/your-namespace
IMAGE_TAG=main-latest

# Domains
WEB_DOMAIN=mianshitong.chat
ADMIN_DOMAIN=admin.mianshitong.chat

# App secrets
AUTH_SECRET=replace_with_a_random_long_secret
ADMIN_AUTH_SECRET=replace_with_a_random_long_secret
NEXTAUTH_URL=https://mianshitong.chat

# Database
DATABASE_URL=postgresql://mianshitong:replace_me@db:5432/mianshitong?schema=public
POSTGRES_USER=mianshitong
POSTGRES_PASSWORD=replace_me
POSTGRES_DB=mianshitong

# AI providers
LLM_PROVIDER=deepseek
EMBEDDING_PROVIDER=ollama
EMBEDDING_VERSION=v1
RUN_LLM_EVALS=0

OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=deepseek-r1:8b
OLLAMA_REASONER_MODEL=deepseek-r1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_EMBED_DIMENSIONS=

DEEPSEEK_API_KEY=replace_me
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_REASONER_MODEL=deepseek-reasoner

# Admin
ADMIN_ALLOWED_IPS=
