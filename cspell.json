  "$schema": "./schemas/cspell.schema.json",
  "version": "0.2",
  "language": "en,zh",
  "allowCompoundWords": true,
  "useGitignore": true,
  "ignorePaths": [
    "schemas/cspell.schema.json",
    "**/node_modules/**",
    "**/.next/**",
    "**/dist/**",
    "**/build/**",
