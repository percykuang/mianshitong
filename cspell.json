    "isready",
    "vitest",
    "shadcn",
    "nums",
    "ollama",
    "ndjson",
    "Segoe",
    "cuid",
    "pkey",
    "fkey",
    "psql",
    "shiki",
    "Shiki",
    "hljs",
    "indexeddb",
    "unstub",
    "legacyab",
    "upvote",
    "downvote",
    "Upvoted",
    "Downvoted"
  ]
