{
  "name": "mianshitong",
  "private": true,
  "packageManager": "pnpm@10.18.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:web": "pnpm -C apps/web dev",
    "dev:admin": "pnpm -C apps/admin dev",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose stop db",
    "db:restart": "docker compose restart db",
    "db:status": "docker compose ps db",
    "db:logs": "docker compose logs -f --tail=200 db",
    "db:psql": "docker compose exec db psql -U mianshitong -d mianshitong",
    "db:studio": "DATABASE_URL=\"${DATABASE_URL:-postgresql://mianshitong:mianshitong@127.0.0.1:5432/mianshitong?schema=public}\" pnpm -C packages/db exec prisma studio --port \"${PRISMA_STUDIO_PORT:-5555}\"",
    "db:migrate": "DATABASE_URL=\"${DATABASE_URL:-postgresql://mianshitong:mianshitong@127.0.0.1:5432/mianshitong?schema=public}\" pnpm -C packages/db exec prisma migrate dev --schema prisma/schema.prisma",
    "db:reset": "DATABASE_URL=\"${DATABASE_URL:-postgresql://mianshitong:mianshitong@127.0.0.1:5432/mianshitong?schema=public}\" pnpm -C packages/db exec prisma migrate reset --schema prisma/schema.prisma --force --skip-seed",
    "db:users": "docker compose exec -T db psql -U mianshitong -d mianshitong -c 'SELECT \"id\", \"email\", \"createdAt\" FROM \"AuthUser\" ORDER BY \"createdAt\" DESC LIMIT 50;'",
    "build": "pnpm -r --if-present build",
    "start:web": "pnpm -C apps/web start",
    "start:admin": "pnpm -C apps/admin start",
    "lint": "pnpm -r --if-present lint && pnpm lint:css && pnpm lint:tailwind",
    "lint:css": "stylelint \"**/*.css\"",
    "lint:css:fix": "stylelint \"**/*.css\" --fix",
    "lint:style": "stylelint \"**/*.css\" --config stylelint.strict.config.mjs",
    "lint:style:fix": "stylelint \"**/*.css\" --config stylelint.strict.config.mjs --fix",
    "format": "prettier -w .",
    "format:check": "prettier -c .",
    "spellcheck": "cspell lint --no-progress .",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "commitlint": "commitlint",
    "prepare": "husky",
    "test:e2e": "playwright test",
    "lint:tailwind": "node scripts/check-tailwind-canonical.mjs"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/js": "^9.39.3",
    "@mianshitong/config": "workspace:*",
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.0.7",
    "cspell": "^9.1.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.0",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "8.46.3",
    "vitest": "^4.0.7"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,md,yaml,yml}": [
      "prettier --write"
    ],
    "*.css": [
      "prettier --write",
      "stylelint --fix"
    ]
  }
}
