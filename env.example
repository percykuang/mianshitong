# Server-side only. Do NOT expose secrets to the browser.
#
# 推荐实践：
# - 本地开发：复制为 .env.local
# - 线上部署：在部署平台配置同名环境变量（不要提交到仓库）

# Auth
AUTH_SECRET=replace_with_a_random_long_secret
ADMIN_AUTH_SECRET=replace_with_a_random_long_secret
# 可选：限制允许访问 Admin 的来源 IP，多个值用逗号分隔
ADMIN_ALLOWED_IPS=
NEXTAUTH_URL=http://127.0.0.1:3000
DATABASE_URL=postgresql://mianshitong:mianshitong@127.0.0.1:5432/mianshitong?schema=public

# Provider selection
# 可选: ollama | deepseek
LLM_PROVIDER=ollama
EMBEDDING_PROVIDER=
EMBEDDING_VERSION=v1
# 手动真实模型评测开关；`pnpm evals:skills:live` 会自动加载 .env/.env.local 并兜底设为 1
RUN_LLM_EVALS=0

# Ollama config
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=deepseek-r1:8b
OLLAMA_REASONER_MODEL=deepseek-r1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_EMBED_DIMENSIONS=

# DeepSeek config (OpenAI-compatible)
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_REASONER_MODEL=deepseek-reasoner
