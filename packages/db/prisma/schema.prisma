generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AuthUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  actor        UserActor?
  chatSessions ChatSessionRecord[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum UserActorType {
  guest
  registered
}

model UserActor {
  id                 String             @id @default(cuid())
  type               UserActorType
  displayName        String
  authUserId         String?            @unique
  guestTokenHash     String?            @unique
  chatSessions       ChatSessionRecord[]
  dailyUsageCounters DailyUsageCounter[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  lastSeenAt         DateTime           @default(now())
  authUser           AuthUser?          @relation(fields: [authUserId], references: [id], onDelete: SetNull)

  @@index([type, lastSeenAt(sort: Desc)])
}

model DailyUsageCounter {
  actorId    String
  dateKey    String
  usedCount  Int       @default(0)
  maxCount   Int
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  actor      UserActor @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@id([actorId, dateKey])
}

model ChatSessionRecord {
  id        String   @id
  actorId   String
  userId    String?
  title     String
  modelId   String
  isPrivate Boolean  @default(true)
  status    String   @default("idle")
  config    Json
  report    Json?
  runtime   Json
  messages  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  actor     UserActor @relation(fields: [actorId], references: [id], onDelete: Cascade)
  user      AuthUser? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([actorId, updatedAt(sort: Desc)])
  @@index([userId, updatedAt(sort: Desc)])
}

model QuestionBankItem {
  id           String               @id @default(cuid())
  questionId   String               @unique
  level        String
  title        String
  prompt       String?
  answer       String?
  keyPoints    Json                 @default("[]")
  followUps    Json                 @default("[]")
  tags         Json                 @default("[]")
  order        Int?
  isActive     Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  retrievalDoc QuestionRetrievalDoc?
}

model QuestionRetrievalDoc {
  id                  String           @id @default(cuid())
  questionItemId      String           @unique
  searchText          String
  normalizedTags      String[]         @default([])
  embedding           Unsupported("vector")?
  embeddingModel      String?
  embeddingVersion    String?
  embeddingDimensions Int?
  contentHash         String
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  questionItem        QuestionBankItem @relation(fields: [questionItemId], references: [id], onDelete: Cascade)

  @@index([embeddingModel, embeddingVersion, embeddingDimensions])
}
